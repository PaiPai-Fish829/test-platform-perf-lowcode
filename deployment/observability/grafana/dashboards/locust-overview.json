{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [
        { "expr": "locust_current_rps{job=\"locust\"}", "refId": "A" }
      ],
      "title": "Current RPS",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "max": 100,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "100 * locust_failure_total{job=\"locust\"} / clamp_min(locust_request_total{job=\"locust\"}, 1)",
          "refId": "A"
        }
      ],
      "title": "Error %",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "kbytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [
        { "expr": "rate(locust_received_bytes_total{job=\"locust\"}[1m]) / 1024", "refId": "A" }
      ],
      "title": "Received KB/sec",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "kbytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [
        { "expr": "rate(locust_sent_bytes_total{job=\"locust\"}[1m]) / 1024", "refId": "A" }
      ],
      "title": "Sent KB/sec",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "max": 100,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"centos-vm\",mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU Usage",
          "refId": "A"
        }
      ],
      "title": "Node CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "node_exporter 无 MemAvailable 时使用 MemFree+Buffers+Cached 估算",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percent",
          "max": 100,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "100 * (1 - (node_memory_MemFree_bytes{job=\"centos-vm\"} + node_memory_Buffers_bytes{job=\"centos-vm\"} + node_memory_Cached_bytes{job=\"centos-vm\"}) / node_memory_MemTotal_bytes{job=\"centos-vm\"})",
          "legendFormat": "Memory Used",
          "refId": "A"
        }
      ],
      "title": "Node Memory Used",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "KBs" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total{job=\"centos-vm\",device!=\"lo\"}[1m])) / 1024",
          "legendFormat": "RX",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_network_transmit_bytes_total{job=\"centos-vm\",device!=\"lo\"}[1m])) / 1024",
          "legendFormat": "TX",
          "refId": "B"
        }
      ],
      "title": "Node Network KB/sec",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["locust", "performance"],
  "templating": { "list": [] },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Locust Overview",
  "uid": "locust-overview",
  "version": 1
}
